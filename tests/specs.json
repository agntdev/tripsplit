            "update_id": 2,
            "callback_query": {
              "id": "2",
              "from": { "id": 1001, "is_bot": false, "first_name": "Alice", "username": "alice" },
              "message": {
                "message_id": 10,
                "date": 0,
                "chat": { "id": -1001, "type": "supergroup", "title": "Trip" },
                "from": { "id": 42, "is_bot": true, "first_name": "TestBot" },
                "text": "(previous)"
              },
              "chat_instance": "ci--1001",
              "data": "ts:members:add"
            }
          }
        },
        "expect": [{ "method": "answerCallbackQuery" }, { "method": "sendMessage" }]
      },
      {
        "send": {
          "update": {
            "update_id": 3,
            "message": {
              "message_id": 3,
              "date": 0,
              "chat": { "id": -1001, "type": "supergroup", "title": "Trip" },
              "from": { "id": 1001, "is_bot": false, "first_name": "Alice", "username": "alice" },
              "text": "add @bob",
              "entities": [
                {
                  "type": "text_mention",
                  "offset": 4,
                  "length": 4,
                  "user": { "id": 1002, "is_bot": false, "first_name": "Bob", "username": "bob" }
                }
              ]
            }
          }
        },
        "expect": [
          {
            "method": "sendMessage",
            "payload": { "text": "Added @bob to the trip." }
          }
        ]
      }
    ]
  },

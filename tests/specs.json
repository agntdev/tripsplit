[
  {
    "name": "help before trip",
    "steps": [
      {
        "send": {
          "update": {
            "update_id": 1,
            "message": {
              "message_id": 1,
              "date": 0,
              "chat": { "id": -1001, "type": "supergroup", "title": "Trip" },
              "from": { "id": 1001, "is_bot": false, "first_name": "Alice", "username": "alice" },
              "text": "❓ Help"
            }
          }
        },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "TripSplit — shared trip expenses\n\nUse the buttons below to:\n• Log Expense — record a shared cost\n• Balances — see who owes what\n• Suggested — minimal repayments\n• Settle — confirm a payment\n• Members — add or remove people\n• Export — audit CSV to your DM\n\nTap 🚀 Start Trip to begin in a new group."
            }
          }
        ]
      }
    ]
  },

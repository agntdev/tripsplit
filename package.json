{
  "name": "tripsplit",
  "version": "0.1.0",
  "private": true,
  "description": "Telegram bot to record, split and settle shared trip expenses.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "npm run build && node --watch dist/index.js",
    "test": "vitest run",
    "test:gate": "npm run build && node scripts/test-gate.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@agntdev/bot-toolkit": "file:.agntdev-bot-toolkit.tgz",
    "grammy": "^1.43.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}